# ═══════════════════════════════════════════════════════════════════════════════
# DEV ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# ALL PASSWORDS/SECRETS come from Vault via generate-runtime-env.sh.
# Do NOT set credential values here. Start with:
#
#   1. docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d vault
#   2. VAULT_TOKEN=$(docker exec ... jq -r '.root_token' vault-init.json)
#   3. VAULT_TOKEN=$VAULT_TOKEN bash infra/vault/seed-secrets.dev.sh
#   4. ENVIRONMENT=dev bash scripts/generate-runtime-env.sh
#   5. docker compose -f docker-compose.yml -f docker-compose.dev.yml \
#        --env-file .env --env-file .env.runtime up -d
#   6. shred -u .env.runtime
# ═══════════════════════════════════════════════════════════════════════════════

# Non-secret Postgres config (credentials come from Vault)
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_IDLE_SESSION_TIMEOUT=5min

# Non-secret MinIO config (credentials come from Vault)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000

# ── Identity (Keycloak) ───────────────────────────────────────────────────────
# Passwords/secrets come from Vault — only non-secret fields here
KEYCLOAK_URL=https://localhost:8443
KEYCLOAK_PUBLIC_URL=https://localhost:8443
WEB_KEYCLOAK_URL=https://keycloak:8443
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_REGISTER_DEFAULT_ROLE=useradmin
KEYCLOAK_REALM=automation-platform
KEYCLOAK_CLIENT_ID=automation-web
WORKFLOW_SERVICE_URL=https://localhost:4001
ORDER_SERVICE_URL=https://localhost:4002
EXECUTION_ENGINE_SERVICE_URL=https://localhost:4003
INTEGRATION_SERVICE_URL=https://localhost:4004
LOGGING_SERVICE_URL=https://localhost:4005
DIFY_API_BASE_URL=http://dify-api:5001
N8N_API_BASE_URL=http://n8n:5678
N8N_WEBHOOK_TOKEN=
RAG_SYNC_PROGRESS_CALLBACK_BASE_URL=https://api-gateway:4000
VAULT_ADDR=http://localhost:8200
VAULT_NAMESPACE=
VAULT_STRICT_SECRETS=true
VAULT_KV_MOUNT=secret
MTLS_REQUIRED=true
TLS_CERT_PATH=/tls/cert.pem
TLS_KEY_PATH=/tls/key.pem
TLS_CA_PATH=/tls/ca.pem
TLS_VERIFY_PEER=true
TLS_RELOAD_DEBOUNCE_MS=1000
TLS_SERVER_NAME=
SECURITY_DIAGNOSTICS_TOKEN=
TLS_CERT_TTL=720h
PKI_LEAF_TTL=720h
CERT_SCAN_INTERVAL_MS=300000
CERT_WARNING_DAYS=7
CERT_CRITICAL_DAYS=3
CERT_ALERT_WEBHOOK_URL=
ROTATION_INTERVAL_SECONDS=20
ROTATION_ENABLE_FALLBACK=false
RESTART_WINDOW_SECONDS=1800
ROTATION_TARGET_CONTAINERS=postgres rabbitmq redis keycloak minio opensearch
# ── OAuth2 Connect Integration ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# PLATFORM_OAUTH_SECRET — sourced from Vault: platform/dev/infra/keycloak/config.platform_oauth_secret

# Public base URL for RapidRAG — dev uses /rapidrag/ path prefix, prod does too
# Dev:  https://dev.eclassmanager.com/rapidrag
# Prod: https://theaitools.ca/rapidrag
PLATFORM_URL=https://dev.eclassmanager.com/rapidrag

# Public base URL for OAuth callbacks (registered with each provider)
# The api-gateway is served at /rapidrag/connect/ in both environments
# Dev:  https://dev.eclassmanager.com/rapidrag/connect
# Prod: https://theaitools.ca/rapidrag/connect
OAUTH_CALLBACK_BASE_URL=https://dev.eclassmanager.com/rapidrag/connect

# Where to redirect browser after successful OAuth connect
OAUTH_POST_CONNECT_REDIRECT=https://dev.eclassmanager.com/rapidrag/integrations

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# github.com → Settings → Developer Settings → OAuth Apps
# Homepage URL:      https://dev.eclassmanager.com/rapidrag
# Callback URL:      https://dev.eclassmanager.com/rapidrag/connect/oauth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitLab OAuth Application ──────────────────────────────────────────────────
# gitlab.com → User Settings → Applications
# Redirect URI:      https://dev.eclassmanager.com/rapidrag/connect/oauth/callback/gitlab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI: https://dev.eclassmanager.com/rapidrag/connect/oauth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Next.js / Web ─────────────────────────────────────────────────────────────
# Internal API base — used server-side inside Docker network
NEXT_PUBLIC_API_BASE_URL=https://localhost:4000
WEB_NEXT_PUBLIC_API_BASE_URL=
WEB_INTERNAL_API_BASE_URL=https://api-gateway:4000
WEB_CERT_IP_SANS=
