REGISTRY_IMAGE_PREFIX=registry.gitlab.com/appleid.balihar-group/automation
APP_IMAGE_TAG=latest
INFRA_IMAGE_TAG=latest

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# ALL PASSWORDS AND SECRETS ARE MANAGED BY VAULT.
# Do NOT set credential values in this file.
# Credentials are injected at deploy time via:
#
#   ENVIRONMENT=prod bash scripts/generate-runtime-env.sh
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml \
#     --env-file .env.production --env-file .env.runtime up -d
#   shred -u .env.runtime
#
# To seed secrets into Vault (run once after Vault bootstrap):
#   VAULT_TOKEN=<root-token> bash infra/vault/seed-secrets.prod.sh
#
# To view seeded secrets:
#   ENVIRONMENT=prod bash scripts/list-secrets.sh
#
# To rotate a secret:
#   ENVIRONMENT=prod SECRET_PATH=infra/postgres/config SECRET_FIELD=password \
#     bash scripts/rotate-secret.sh
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# Values below come from Vault via generate-runtime-env.sh — do not set here
# POSTGRES_USER        sourced from Vault: platform/prod/infra/postgres/config.user
# POSTGRES_PASSWORD    sourced from Vault: platform/prod/infra/postgres/config.password
# POSTGRES_DB          sourced from Vault: platform/prod/infra/postgres/config.db
# DATABASE_URL         constructed by generate-runtime-env.sh
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_IDLE_SESSION_TIMEOUT=5min

# ── Cache ─────────────────────────────────────────────────────────────────────
# REDIS_PASSWORD  sourced from Vault: platform/prod/infra/redis/config.password
# REDIS_URL       constructed by generate-runtime-env.sh

# ── Message Bus ───────────────────────────────────────────────────────────────
# RABBITMQ_DEFAULT_USER  sourced from Vault: platform/prod/infra/rabbitmq/config.username
# RABBITMQ_DEFAULT_PASS  sourced from Vault: platform/prod/infra/rabbitmq/config.password
# RABBITMQ_URL           constructed by generate-runtime-env.sh

# ── Search ────────────────────────────────────────────────────────────────────
# OPENSEARCH_INITIAL_ADMIN_PASSWORD  sourced from Vault: platform/prod/infra/opensearch/config.admin_password
# OPENSEARCH_URL                     constructed by generate-runtime-env.sh

# ── Object Storage ────────────────────────────────────────────────────────────
# MINIO_ACCESS_KEY  sourced from Vault: platform/prod/infra/minio/config.access_key
# MINIO_SECRET_KEY  sourced from Vault: platform/prod/infra/minio/config.secret_key
MINIO_ENDPOINT=localhost
MINIO_PORT=9000

# ── Identity (Keycloak) ───────────────────────────────────────────────────────
# KEYCLOAK_ADMIN_PASSWORD  sourced from Vault: platform/prod/infra/keycloak/config.admin_password
# KEYCLOAK_CLIENT_SECRET   sourced from Vault: platform/prod/infra/keycloak/config.client_secret
# PLATFORM_OAUTH_SECRET    sourced from Vault: platform/prod/infra/keycloak/config.platform_oauth_secret
KEYCLOAK_URL=https://theaitools.ca:8443
KEYCLOAK_PUBLIC_URL=https://theaitools.ca:8443
WEB_KEYCLOAK_URL=https://keycloak:8443
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_REGISTER_DEFAULT_ROLE=useradmin
KEYCLOAK_REALM=automation-platform
KEYCLOAK_CLIENT_ID=automation-web

# ── Internal Services ─────────────────────────────────────────────────────────
WORKFLOW_SERVICE_URL=https://localhost:4001
LOGGING_SERVICE_URL=https://localhost:4005

# ── RAG / AI ──────────────────────────────────────────────────────────────────
# N8N_ENCRYPTION_KEY  sourced from Vault: platform/prod/app/n8n/config.encryption_key
# N8N_DB_PASSWORD     sourced from Vault: platform/prod/app/n8n/config.db_password
# N8N_WEBHOOK_TOKEN   sourced from Vault: platform/prod/app/n8n/config.webhook_token
# DIFY_SECRET_KEY     sourced from Vault: platform/prod/app/dify/config.secret_key
# DIFY_DB_PASSWORD    sourced from Vault: platform/prod/app/dify/config.db_password
# DIFY_REDIS_PASSWORD sourced from Vault: platform/prod/app/dify/config.redis_password
DIFY_API_BASE_URL=http://dify-api:5001
N8N_API_BASE_URL=http://n8n:5678
RAG_SYNC_PROGRESS_CALLBACK_BASE_URL=https://api-gateway:4000

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_NAMESPACE=
VAULT_STRICT_SECRETS=true
VAULT_KV_MOUNT=secret

# ── TLS / mTLS ────────────────────────────────────────────────────────────────
MTLS_REQUIRED=true
TLS_CERT_PATH=/tls/cert.pem
TLS_KEY_PATH=/tls/key.pem
TLS_CA_PATH=/tls/ca.pem
TLS_VERIFY_PEER=true
TLS_RELOAD_DEBOUNCE_MS=1000
TLS_SERVER_NAME=
SECURITY_DIAGNOSTICS_TOKEN=
TLS_CERT_TTL=720h
PKI_LEAF_TTL=720h
CERT_SCAN_INTERVAL_MS=300000
CERT_WARNING_DAYS=7
CERT_CRITICAL_DAYS=3
CERT_ALERT_WEBHOOK_URL=
ROTATION_INTERVAL_SECONDS=20
ROTATION_ENABLE_FALLBACK=true
RESTART_WINDOW_SECONDS=86400
ROTATION_TARGET_CONTAINERS=postgres rabbitmq redis keycloak minio opensearch

# ── OAuth2 Providers ──────────────────────────────────────────────────────────
PLATFORM_URL=https://theaitools.ca/rapidrag
OAUTH_CALLBACK_BASE_URL=https://theaitools.ca/rapidrag/connect
OAUTH_POST_CONNECT_REDIRECT=https://theaitools.ca/rapidrag/integrations

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Next.js / Web ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://theaitools.ca/rapidrag/gateway
WEB_NEXT_PUBLIC_API_BASE_URL=
WEB_INTERNAL_API_BASE_URL=https://api-gateway:4000
WEB_CERT_IP_SANS=
NEXT_PUBLIC_PLATFORM_URL=https://theaitools.ca/rapidrag
