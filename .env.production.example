REGISTRY_IMAGE_PREFIX=registry.gitlab.com/appleid.balihar-group/automation
APP_IMAGE_TAG=latest
INFRA_IMAGE_TAG=latest

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=automation
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_IDLE_SESSION_TIMEOUT=5min
DATABASE_URL=postgresql://platform:CHANGE_ME_strong_password@localhost:5432/automation?schema=public&sslmode=verify-full

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=rediss://:CHANGE_ME_redis_password@localhost:6379

# ── Message Bus ───────────────────────────────────────────────────────────────
RABBITMQ_URL=amqps://guest:CHANGE_ME_rabbit_password@localhost:5671

# ── Search ────────────────────────────────────────────────────────────────────
OPENSEARCH_URL=https://admin:CHANGE_ME_opensearch_password@localhost:9200

# ── Object Storage ────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret

# ── Identity (Keycloak) ───────────────────────────────────────────────────────
# NOTE: Keycloak realm and client IDs are kept as-is from dev — no rename needed
# unless you re-export the realm. Update the URLs only.
KEYCLOAK_URL=https://theaitools.ca:8443
KEYCLOAK_PUBLIC_URL=https://theaitools.ca:8443
WEB_KEYCLOAK_URL=https://keycloak:8443
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password
KEYCLOAK_REGISTER_DEFAULT_ROLE=useradmin
KEYCLOAK_REALM=automation-platform
KEYCLOAK_CLIENT_ID=automation-web
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_client_secret

# ── Internal Services ─────────────────────────────────────────────────────────
WORKFLOW_SERVICE_URL=https://localhost:4001
ORDER_SERVICE_URL=https://localhost:4002
EXECUTION_ENGINE_SERVICE_URL=https://localhost:4003
INTEGRATION_SERVICE_URL=https://localhost:4004
LOGGING_SERVICE_URL=https://localhost:4005

# ── RAG / AI ──────────────────────────────────────────────────────────────────
DIFY_API_BASE_URL=http://dify-api:5001
N8N_API_BASE_URL=http://n8n:5678
N8N_WEBHOOK_TOKEN=CHANGE_ME_n8n_webhook_token
RAG_SYNC_PROGRESS_CALLBACK_BASE_URL=https://api-gateway:4000

# ── Vault ─────────────────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_NAMESPACE=
VAULT_STRICT_SECRETS=true
VAULT_KV_MOUNT=secret

# ── TLS / mTLS ────────────────────────────────────────────────────────────────
MTLS_REQUIRED=true
TLS_CERT_PATH=/tls/cert.pem
TLS_KEY_PATH=/tls/key.pem
TLS_CA_PATH=/tls/ca.pem
TLS_VERIFY_PEER=true
TLS_RELOAD_DEBOUNCE_MS=1000
TLS_SERVER_NAME=
SECURITY_DIAGNOSTICS_TOKEN=CHANGE_ME_diagnostics_token
TLS_CERT_TTL=8760h
PKI_LEAF_TTL=8760h
CERT_SCAN_INTERVAL_MS=300000
CERT_WARNING_DAYS=7
CERT_CRITICAL_DAYS=3
CERT_ALERT_WEBHOOK_URL=
ROTATION_INTERVAL_SECONDS=20
ROTATION_ENABLE_FALLBACK=false
RESTART_WINDOW_SECONDS=1800
ROTATION_TARGET_CONTAINERS=postgres rabbitmq redis keycloak minio opensearch

# ── OAuth2 Connect Integration ─────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PLATFORM_OAUTH_SECRET=CHANGE_ME_openssl_rand_hex_32

# Public base URL for your platform — production uses /rapidrag/ path prefix
PLATFORM_URL=https://theaitools.ca/rapidrag

# Public base URL for OAuth callbacks — registered with each provider
# The outer nginx strips /rapidrag before passing to the app,
# so callbacks hit /connect/... (same as dev, just different domain)
OAUTH_CALLBACK_BASE_URL=https://theaitools.ca/rapidrag/connect

# Where to redirect browser after successful OAuth connect
OAUTH_POST_CONNECT_REDIRECT=https://theaitools.ca/rapidrag/integrations

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitLab OAuth Application ──────────────────────────────────────────────────
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Next.js API ───────────────────────────────────────────────────────────────
# The outer nginx at theaitools.ca proxies /rapidrag/ → this container.
# The inner nginx in the container serves Next.js at /.
# So NEXT_PUBLIC_API_BASE_URL stays as-is (relative to the app root).
NEXT_PUBLIC_API_BASE_URL=https://theaitools.ca/rapidrag/gateway
WEB_NEXT_PUBLIC_API_BASE_URL=
WEB_INTERNAL_API_BASE_URL=https://api-gateway:4000
WEB_CERT_IP_SANS=
