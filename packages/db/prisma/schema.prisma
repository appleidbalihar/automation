generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformLog {
  id            String   @id @default(cuid())
  severity      String
  source        String
  message       String
  maskedPayload Json?
  correlationId String?
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([source, createdAt])
  @@index([correlationId])
  @@index([severity, createdAt])
}

// ─── RAG Knowledge Base ──────────────────────────────────────────────────────
// Every KB is owned by a specific user (ownerId = Keycloak preferred_username).
// There is no "global" scope — admins own their KBs and share them explicitly.
// The Dify API key is stored in Vault at:
//   secret/data/platform/global/dify/{id}  →  app_api_key
// Source credentials (GitHub token, GitLab token, Google Drive OAuth) are stored
// in Vault at:
//   secret/data/platform/users/{ownerId}/sources/{id}
model RagKnowledgeBase {
  id            String   @id @default(cuid())
  name          String
  description   String?

  // Document source configuration (non-secret — credentials go in Vault)
  sourceType    String   // "github" | "gitlab" | "googledrive" | "web" | "upload"
  sourceUrl     String   // Repo URL, Drive folder URL, web URL, or "manual"
  sourceBranch  String?   // For git sources: "main", "master"
  sourcePath    String?   // Optional subfolder filter: "docs/" (legacy, kept for compat)
  sourcePaths   String[]  @default([]) // Array of subfolder filters (e.g. ["docs/operations", "docs/architecture"])
  syncSchedule  String?   // Cron expression or null (manual only). e.g. "0 */6 * * *"

  // Dify app config (non-secret — API key goes in Vault)
  difyAppUrl    String   @default("http://dify-api:5001")
  difyDatasetId String?  // Dify Knowledge Base dataset ID (set after first sync)

  // Ownership — every KB has an owner (Keycloak preferred_username)
  // No global scope: admins own KBs and share them explicitly via RagKbShare
  ownerId       String   // Keycloak preferred_username of the creator
  ownerUsername String   // Display username (matches ownerId; kept separate for auditability)
  isDefault     Boolean  @default(false)   // User's personal default KB for new threads
  createdById   String   // Same as ownerId at creation time

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  threads       RagDiscussionThread[]
  config        RagKnowledgeBaseConfig?
  syncJobs      RagKbSyncJob[]
  deployments   RagChannelDeployment[]
  shares        RagKbShare[]           // Users this KB is shared with
  trackedFiles  RagKbFileTracker[]     // Files successfully synced to Dify

  @@index([ownerId])
  @@index([isDefault])
  @@index([createdById])
}

// ─── KB Share Records ─────────────────────────────────────────────────────────
// Tracks which users a KB owner (or platform admin) has granted chat access to.
// Shared users can query the KB but cannot edit, delete, or trigger syncs.
model RagKbShare {
  id                String           @id @default(cuid())
  knowledgeBaseId   String
  knowledgeBase     RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  sharedWithId      String           // Keycloak preferred_username of the recipient
  sharedById        String           // Keycloak preferred_username of the granter (owner or admin)
  permission        String           @default("chat")  // "chat" — extensible for future "write"

  createdAt         DateTime         @default(now())

  @@unique([knowledgeBaseId, sharedWithId])  // one share record per user per KB
  @@index([sharedWithId])
  @@index([knowledgeBaseId])
}

// Per-KB configuration: admin sets platform defaults, users can override selectively.
model RagKnowledgeBaseConfig {
  id                String           @id @default(cuid())
  knowledgeBaseId   String           @unique
  knowledgeBase     RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  // Admin-controlled platform defaults
  systemPromptBase  String?  // Base system prompt template set by admin
  llmModel          String?  // e.g. "gpt-4o-mini"
  temperature       Float?   // 0.0 – 1.0, default 0.2
  topK              Int?     // Number of chunks retrieved, default 6

  // User-customizable overrides (users can adjust these without admin)
  responseStyle     String?  // "formal" | "casual" | "technical" | "friendly"
  toneInstructions  String?  // Free-text: "Always be concise, use bullet points"
  restrictionRules  String?  // "Only answer questions about topic X"
  welcomeMessage    String?  // Custom greeting shown at chat start

  updatedAt         DateTime @updatedAt

  @@index([knowledgeBaseId])
}

// Tracks individual files that have been successfully synced to Dify.
// Used for incremental syncing (skip unchanged, update changed, delete removed).
model RagKbFileTracker {
  id                String           @id @default(cuid())
  knowledgeBaseId   String
  knowledgeBase     RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  filePath          String           // Path in the repository (e.g. "docs/operations/runbook.md")
  fileSha           String           // Git blob SHA (to detect modifications)
  difyDocumentId    String           // The document ID in Dify (to perform update_by_text or delete)

  syncedAt          DateTime         @default(now())

  @@unique([knowledgeBaseId, filePath])
  @@index([knowledgeBaseId])
}

// Tracks each document sync job — used to show progress in the UI.
// Created when a sync is triggered; updated by n8n webhook callbacks.
model RagKbSyncJob {
  id                String           @id @default(cuid())
  knowledgeBaseId   String
  knowledgeBase     RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  trigger           String           // "manual" | "scheduled" | "webhook"
  triggeredById     String?          // userId who triggered (null = scheduled)
  status            String           @default("pending") // "pending"|"running"|"completed"|"failed"

  // Progress tracking (updated by n8n callbacks)
  filesTotal        Int?
  filesProcessed    Int              @default(0)
  chunksTotal       Int?
  chunksProcessed   Int              @default(0)
  errorMessage      String?

  // n8n execution reference for traceability
  n8nExecutionId    String?
  n8nWebhookUrl     String?

  // Dynamic workflow step tracking — populated by n8n progress callbacks
  // JSON array of: [{name, status, startedAt, completedAt, errorMessage, logRef}]
  stepsJson         Json?

  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  lastProgressAt    DateTime?

  @@index([knowledgeBaseId, createdAt])
  @@index([status])
  @@index([triggeredById])
}

// Channel deployment — tracks where a KB is deployed for chat delivery.
// Phase 2: n8n activates a pre-built workflow for each channel type.
model RagChannelDeployment {
  id              String           @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  channelType     String   // "slack" | "discord" | "whatsapp" | "telegram" | "google_chat"
  channelName     String   // User-defined label: "My Company Slack"
  n8nWorkflowId   String?  // n8n workflow ID (set after activation)
  status          String   @default("pending") // "pending"|"active"|"error"|"disabled"
  ownerId         String   // User who configured this channel
  errorMessage    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId, channelType])
  @@index([knowledgeBaseId])
  @@index([status])
}

// ─── RAG Discussion Threads and Messages ─────────────────────────────────────
// Threads are strictly private: only the ownerId user can see their own threads.
// Sharing a KB does NOT share thread history — each user has their own sessions.
// Multi-KB threads use RagDiscussionKbSession to track per-KB Dify conversation IDs.
model RagDiscussionThread {
  id                 String                   @id @default(cuid())
  ownerId            String                   // Strict: only this user sees this thread

  // Optional link to a single knowledge base (kept for legacy compatibility)
  knowledgeBaseId    String?
  knowledgeBase      RagKnowledgeBase?        @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)

  // Multi-KB sessions: one entry per KB selected for this thread
  kbSessions         RagDiscussionKbSession[]

  title              String
  // Legacy: Flowise session ID for pre-Dify threads
  flowiseSessionId   String                   @unique
  // Legacy single-KB Dify conversation ID (kept for backward compat)
  difyConversationId String?

  lastMessageAt      DateTime
  expiresAt          DateTime
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  messages           RagDiscussionMessage[]

  @@index([ownerId, lastMessageAt])
  @@index([expiresAt])
  @@index([knowledgeBaseId])
}

// Per-KB Dify session within a multi-KB discussion thread.
// Each selected KB has its own Dify conversation_id for follow-up context continuity.
model RagDiscussionKbSession {
  id                  String              @id @default(cuid())
  threadId            String
  thread              RagDiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  knowledgeBaseId     String
  knowledgeBaseName   String              // Snapshot of KB name at session creation time
  difyConversationId  String?             // Dify's conversation_id for this KB in this thread

  @@unique([threadId, knowledgeBaseId])
  @@index([threadId])
}

// Discussion messages — stores both user questions and assistant answers.
// For multi-KB responses, kbResults holds the per-KB labeled answers as JSON.
model RagDiscussionMessage {
  id         String              @id @default(cuid())
  threadId   String
  role       String              // "user" | "assistant"
  content    String              // Combined/formatted content (all KBs merged for display)
  kbResults  Json?               // Array: [{knowledgeBaseId, knowledgeBaseName, ownerUsername, answer}]
  createdAt  DateTime            @default(now())
  thread     RagDiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
