generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id              String            @id @default(cuid())
  name            String
  description     String?
  latestVersionId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  versions        WorkflowVersion[]
}

model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  version    Int
  status     String
  nodesJson  Json
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
}

model Order {
  id                String              @id @default(cuid())
  workflowVersionId String
  environmentId     String?
  status            String
  currentNodeOrder  Int                 @default(0)
  currentStepIndex  Int                 @default(0)
  failurePolicy     String
  correlationId     String              @unique
  lastError         String?
  inputJson         Json
  envSnapshotJson   Json?
  initiatedBy       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  checkpoints       ExecutionCheckpoint[]
  transitions       StatusTransition[]
  stepExecutions    StepExecution[]
  approvals         ApprovalDecision[]
}

model IntegrationProfile {
  id             String   @id @default(cuid())
  name           String
  ownerId        String
  executionType  String
  authType       String   @default("API_KEY")
  lifecycleState String   @default("ACTIVE")
  baseConfigJson Json?
  credentialJson Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shares         IntegrationShare[]

  @@index([ownerId, updatedAt])
}

model UserEnvironment {
  id            String   @id @default(cuid())
  name          String
  ownerId       String
  variablesJson Json
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shares        EnvironmentShare[]

  @@index([ownerId, updatedAt])
}

model IntegrationShare {
  id               String             @id @default(cuid())
  integrationId    String
  sharedWithUserId String
  createdBy        String
  createdAt        DateTime           @default(now())
  integration      IntegrationProfile @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt])
}

model EnvironmentShare {
  id               String          @id @default(cuid())
  environmentId    String
  sharedWithUserId String
  createdBy        String
  createdAt        DateTime        @default(now())
  environment      UserEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt])
}

model ExecutionCheckpoint {
  id         String   @id @default(cuid())
  orderId    String
  nodeOrder  Int
  stepIndex  Int
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StatusTransition {
  id        String   @id @default(cuid())
  orderId   String
  from      String
  to        String
  reason    String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StepExecution {
  id              String   @id @default(cuid())
  orderId         String
  nodeId          String
  stepId          String
  status          String
  retryCount      Int
  durationMs      Int
  errorSource     String?
  errorMessage    String?
  requestPayload  Json?
  responsePayload Json?
  startedAt       DateTime
  finishedAt      DateTime
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ExecutionLog {
  id            String   @id @default(cuid())
  orderId       String
  nodeId        String?
  stepId        String?
  severity      String
  source        String
  maskedPayload Json?
  message       String
  durationMs    Int?
  createdAt     DateTime @default(now())
}

model ChatHistory {
  id         String   @id @default(cuid())
  userId     String
  query      String
  answer     String
  workflowId String?
  orderId    String?
  createdAt  DateTime @default(now())
}

model WorkflowPublishAudit {
  id                String   @id @default(cuid())
  workflowId        String
  workflowVersionId String   @unique
  version           Int
  correlationId     String?
  eventTimestamp    DateTime?
  status            String
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RagIndexJob {
  id                 String   @id @default(cuid())
  source             String
  correlationId      String?
  requestedDocuments Int?
  status             String
  errorMessage       String?
  processedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RagDocument {
  id         String   @id @default(cuid())
  source     String
  externalId String
  title      String
  text       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([source, externalId])
}

model ApprovalDecision {
  id        String   @id @default(cuid())
  orderId   String
  nodeOrder Int?
  decision  String
  decidedBy String
  comment   String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}
