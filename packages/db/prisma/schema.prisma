generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformLog {
  id            String   @id @default(cuid())
  severity      String
  source        String
  message       String
  maskedPayload Json?
  correlationId String?
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([source, createdAt])
  @@index([correlationId])
  @@index([severity, createdAt])
}

// ─── RAG Knowledge Base ──────────────────────────────────────────────────────
// Represents a user-configured knowledge source. Each KB maps to one Dify App.
// The Dify API key is stored in Vault at:
//   secret/data/platform/global/dify/{id}  →  api_key
// Source credentials (GitHub token, GitLab token, Google Drive OAuth) are stored
// in Vault at:
//   secret/data/platform/users/{ownerId}/sources/{id}
model RagKnowledgeBase {
  id            String   @id @default(cuid())
  name          String
  description   String?

  // Document source configuration (non-secret — credentials go in Vault)
  sourceType    String   // "github" | "gitlab" | "googledrive" | "web" | "upload"
  sourceUrl     String   // Repo URL, Drive folder URL, web URL, or "manual"
  sourceBranch  String?  // For git sources: "main", "master"
  sourcePath    String?  // Optional subfolder filter: "docs/"
  syncSchedule  String?  // Cron expression or null (manual only). e.g. "0 */6 * * *"

  // Dify app config (non-secret — API key goes in Vault)
  difyAppUrl    String   @default("http://dify-api:5001")
  difyDatasetId String?  // Dify Knowledge Base dataset ID (set after first sync)

  // Scope and ownership
  scope         String   @default("global") // "global" | "user"
  ownerId       String?  // null = platform-wide KB; set = user-scoped KB
  isDefault     Boolean  @default(false)    // Platform default KB for new threads
  createdById   String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  threads       RagDiscussionThread[]
  config        RagKnowledgeBaseConfig?
  syncJobs      RagKbSyncJob[]
  deployments   RagChannelDeployment[]

  @@index([ownerId, scope])
  @@index([isDefault])
  @@index([createdById])
}

// Per-KB configuration: admin sets platform defaults, users can override selectively.
model RagKnowledgeBaseConfig {
  id                String           @id @default(cuid())
  knowledgeBaseId   String           @unique
  knowledgeBase     RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  // Admin-controlled platform defaults
  systemPromptBase  String?  // Base system prompt template set by admin
  llmModel          String?  // e.g. "gpt-4o-mini"
  temperature       Float?   // 0.0 – 1.0, default 0.2
  topK              Int?     // Number of chunks retrieved, default 6

  // User-customizable overrides (users can adjust these without admin)
  responseStyle     String?  // "formal" | "casual" | "technical" | "friendly"
  toneInstructions  String?  // Free-text: "Always be concise, use bullet points"
  restrictionRules  String?  // "Only answer questions about topic X"
  welcomeMessage    String?  // Custom greeting shown at chat start

  updatedAt         DateTime @updatedAt

  @@index([knowledgeBaseId])
}

// Tracks each document sync job — used to show progress in the UI.
// Created when a sync is triggered; updated by n8n webhook callbacks.
model RagKbSyncJob {
  id                String           @id @default(cuid())
  knowledgeBaseId   String
  knowledgeBase     RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  trigger           String           // "manual" | "scheduled" | "webhook"
  triggeredById     String?          // userId who triggered (null = scheduled)
  status            String           @default("pending") // "pending"|"running"|"completed"|"failed"

  // Progress tracking (updated by n8n callbacks)
  filesTotal        Int?
  filesProcessed    Int              @default(0)
  chunksTotal       Int?
  chunksProcessed   Int              @default(0)
  errorMessage      String?

  // n8n execution reference for traceability
  n8nExecutionId    String?
  n8nWebhookUrl     String?

  // Dynamic workflow step tracking — populated by n8n progress callbacks
  // JSON array of: [{name, status, startedAt, completedAt, errorMessage, logRef}]
  stepsJson         Json?

  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())

  @@index([knowledgeBaseId, createdAt])
  @@index([status])
  @@index([triggeredById])
}

// Channel deployment — tracks where a KB is deployed for chat delivery.
// Phase 2: n8n activates a pre-built workflow for each channel type.
model RagChannelDeployment {
  id              String           @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   RagKnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  channelType     String   // "slack" | "discord" | "whatsapp" | "telegram" | "google_chat"
  channelName     String   // User-defined label: "My Company Slack"
  n8nWorkflowId   String?  // n8n workflow ID (set after activation)
  status          String   @default("pending") // "pending"|"active"|"error"|"disabled"
  ownerId         String   // User who configured this channel
  errorMessage    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ownerId, channelType])
  @@index([knowledgeBaseId])
  @@index([status])
}

// ─── RAG Discussion Threads and Messages ─────────────────────────────────────
// Threads persist conversation context. flowiseSessionId is kept for backward
// compatibility with legacy Flowise-backed threads. New Dify threads use
// difyConversationId which Dify manages for session continuity.
model RagDiscussionThread {
  id                 String                 @id @default(cuid())
  ownerId            String

  // Optional link to a knowledge base (null = legacy Flowise thread)
  knowledgeBaseId    String?
  knowledgeBase      RagKnowledgeBase?      @relation(fields: [knowledgeBaseId], references: [id], onDelete: SetNull)

  title              String
  // Legacy: Flowise session ID for pre-Dify threads
  flowiseSessionId   String                 @unique
  // Dify: conversation_id returned by Dify API (enables follow-up context)
  difyConversationId String?

  lastMessageAt      DateTime
  expiresAt          DateTime
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  messages           RagDiscussionMessage[]

  @@index([ownerId, lastMessageAt])
  @@index([expiresAt])
  @@index([knowledgeBaseId])
}

model RagDiscussionMessage {
  id        String              @id @default(cuid())
  threadId  String
  role      String              // "user" | "assistant"
  content   String
  createdAt DateTime            @default(now())
  thread    RagDiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}
