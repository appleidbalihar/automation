generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id              String            @id @default(cuid())
  name            String
  description     String?
  latestVersionId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  versions        WorkflowVersion[]
}

model WorkflowVersion {
  id         String   @id @default(cuid())
  workflowId String
  version    Int
  status     String
  isActive   Boolean  @default(false)
  nodesJson  Json
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, version])
}

model Order {
  id                String              @id @default(cuid())
  workflowVersionId String
  environmentId     String?
  status            String
  currentNodeOrder  Int                 @default(0)
  currentStepIndex  Int                 @default(0)
  failurePolicy     String
  correlationId     String              @unique
  lastError         String?
  inputJson         Json
  envSnapshotJson   Json?
  initiatedBy       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  checkpoints       ExecutionCheckpoint[]
  transitions       StatusTransition[]
  stepExecutions    StepExecution[]
  approvals         ApprovalDecision[]
}

model IntegrationProfile {
  id             String   @id @default(cuid())
  name           String
  ownerId        String
  executionType  String
  authType       String   @default("API_KEY")
  lifecycleState String   @default("ACTIVE")
  baseConfigJson Json?
  credentialJson Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shares         IntegrationShare[]

  @@index([ownerId, updatedAt])
}

model UserEnvironment {
  id            String   @id @default(cuid())
  name          String
  ownerId       String
  variablesJson Json
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shares        EnvironmentShare[]

  @@index([ownerId, updatedAt])
}

model IntegrationShare {
  id               String             @id @default(cuid())
  integrationId    String
  sharedWithUserId String
  createdBy        String
  createdAt        DateTime           @default(now())
  integration      IntegrationProfile @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt])
}

model EnvironmentShare {
  id               String          @id @default(cuid())
  environmentId    String
  sharedWithUserId String
  createdBy        String
  createdAt        DateTime        @default(now())
  environment      UserEnvironment @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([environmentId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt])
}

model ExecutionCheckpoint {
  id         String   @id @default(cuid())
  orderId    String
  nodeOrder  Int
  stepIndex  Int
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StatusTransition {
  id        String   @id @default(cuid())
  orderId   String
  from      String
  to        String
  reason    String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StepExecution {
  id              String   @id @default(cuid())
  orderId         String
  nodeId          String
  stepId          String
  status          String
  retryCount      Int
  durationMs      Int
  errorSource     String?
  errorMessage    String?
  requestPayload  Json?
  responsePayload Json?
  startedAt       DateTime
  finishedAt      DateTime
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ExecutionLog {
  id            String   @id @default(cuid())
  orderId       String
  executionId   String?
  workflowId    String?
  workflowVersionId String?
  nodeId        String?
  stepId        String?
  taskId        String?
  initiatedBy   String?
  severity      String
  source        String
  maskedPayload Json?
  message       String
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([executionId, createdAt])
  @@index([workflowId, workflowVersionId, createdAt])
}

model WorkflowPublishAudit {
  id                String   @id @default(cuid())
  workflowId        String
  workflowVersionId String   @unique
  version           Int
  correlationId     String?
  eventTimestamp    DateTime?
  status            String
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ApprovalDecision {
  id        String   @id @default(cuid())
  orderId   String
  nodeOrder Int?
  decision  String
  decidedBy String
  comment   String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model RagDiscussionThread {
  id              String                 @id @default(cuid())
  ownerId         String
  title           String
  flowiseSessionId String                @unique
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  lastMessageAt   DateTime
  expiresAt       DateTime
  messages        RagDiscussionMessage[]

  @@index([ownerId, lastMessageAt])
  @@index([expiresAt])
}

model RagDiscussionMessage {
  id        String              @id @default(cuid())
  threadId   String
  role      String
  content   String
  createdAt DateTime            @default(now())
  thread    RagDiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model NodeTemplate {
  id           String              @id @default(cuid())
  ownerId      String
  name         String
  description  String?
  category     String?
  tagsJson     Json?
  nodeType     String
  configJson   Json
  metadataJson Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  shares       NodeTemplateShare[]

  @@index([ownerId, updatedAt])
  @@index([nodeType, updatedAt])
}

model NodeTemplateShare {
  id               String       @id @default(cuid())
  templateId       String
  sharedWithUserId String
  createdBy        String
  createdAt        DateTime     @default(now())
  template         NodeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, sharedWithUserId])
  @@index([sharedWithUserId, createdAt])
}
