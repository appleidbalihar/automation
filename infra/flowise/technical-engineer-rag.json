            "type": "string",
            "rows": 4,
            "description": "Each document loader comes with default metadata. Use comma-separated keys to omit some of them, or * to omit all default metadata keys.",
            "placeholder": "key1, key2, key3.nestedKey1",
            "optional": true,
            "additionalParams": true,
            "id": "github_0-input-omitMetadataKeys-string"
          }
        ],
        "inputAnchors": [
          {
